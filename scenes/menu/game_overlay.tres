code = "shader_type canvas_item;
render_mode blend_mix;




void fragment() {
// Input:9
	vec4 n_out9p0 = COLOR;


// ColorConstant:20
	vec4 n_out20p0 = vec4(0.900000, 0.900000, 0.750000, 1.000000);


	vec3 n_out13p0;
// ColorFunc:13
	{
		vec3 c = vec3(n_out9p0.xyz);
		float max1 = max(c.r, c.g);
		float max2 = max(max1, c.b);
		n_out13p0 = vec3(max2, max2, max2);
	}


	vec3 n_out19p0;
// If:19
	float n_in19p2 = 0.00001;
	vec3 n_in19p3 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in19p4 = vec3(0.00000, 0.00000, 0.00000);
	if(abs(n_out9p0.x - n_out20p0.x) < n_in19p2)
	{
		n_out19p0 = n_in19p3;
	}
	else if(n_out9p0.x < n_out20p0.x)
	{
		n_out19p0 = n_out13p0;
	}
	else
	{
		n_out19p0 = n_in19p4;
	}


// ColorConstant:6
	vec4 n_out6p0 = vec4(0.810440, 0.097470, 0.127577, 1.000000);


// Mix:12
	vec4 n_in12p2 = vec4(0.50000, 0.50000, 0.50000, 0.50000);
	vec4 n_out12p0 = mix(vec4(n_out19p0, 0.0), n_out6p0, n_in12p2);


// ColorOp:8
	vec3 n_in8p1 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out8p0 = vec3(1.0) - (vec3(1.0) - vec3(n_out12p0.xyz)) * (vec3(1.0) - n_in8p1);


// Output:0
	COLOR.rgb = n_out8p0;


}
